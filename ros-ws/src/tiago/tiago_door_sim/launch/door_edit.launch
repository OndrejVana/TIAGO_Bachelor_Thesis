<?xml version="1.0"?>
<launch>
  <!-- World-only Gazebo launch (no robot) -->

  <arg name="world_file" default="$(find tiago_door_sim)/worlds/small_office_with_door.world"/>
  <arg name="gui" default="true"/>
  <arg name="paused" default="false"/>
  <arg name="debug" default="false"/>
  <arg name="extra_gazebo_args" default=""/>

  <!-- Make Gazebo find custom models (door, tag, etc.) -->
  <env name="GAZEBO_MODEL_PATH"
       value="$(find tiago_door_sim)/models:$(optenv GAZEBO_MODEL_PATH)"/>

  <!-- Use sim time -->
  <param name="/use_sim_time" value="true"/>

  <!-- Start Gazebo with world -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(arg world_file)"/>
    <arg name="gui" value="$(arg gui)"/>
    <arg name="paused" value="$(arg paused)"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="debug" value="$(arg debug)"/>
    <arg name="extra_gazebo_args" value="$(arg extra_gazebo_args)"/>
  </include>
</launch>