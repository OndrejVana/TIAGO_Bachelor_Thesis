<?xml version="1.0"?>
<launch>
  <!-- Global Configuration -->
  <arg name="simulation" default="true" doc="true = Gazebo sim, false = real robot"/>
  <arg name="use_slam" default="true" doc="Enable SLAM for mapping and localization"/>
  <arg name="use_door_perception" default="false" doc="Enable AprilTag-based door detection"/>
  <arg name="use_navigation" default="true" doc="Enable navigation (move_base) control"/>
  <arg name="use_door_planning" default="false" doc="Enable door-opening trajectory planning"/>
  <arg name="use_arm_manipulation" default="true" doc="Enable arm motion planning and gripper control"/>
  <arg name="use_behavior_tree" default="false" doc="Enable BT-based door navigation"/>
  <arg name="use_vicon" default="false" doc="Enable VICON motion capture system"/>
  <arg name="rviz" default="true" doc="Launch RViz for visualization"/>

  
  <!-- Simulation Configuration -->
  <arg name="world_file" default="$(find tiago_door_sim)/worlds/small_office_with_door.world"/>
  <!-- robot: iron (no-arm), steel (gripper), titanium (hey5), tiago++ (dual-arm) -->
  <arg name="robot" default="tiago++" doc="Robot model: iron, steel, titanium, or tiago++"/>
  <!-- Single-arm variants -->
  <arg name="arm" default="$(eval arg('robot') not in ['iron'])"/>
  <arg name="end_effector" default="$(eval {'iron': 'false', 'steel': 'pal-gripper', 'titanium': 'pal-hey5'}.get(arg('robot'), 'pal-hey5'))"/>
  <arg name="end_effector_left"  default="pal-hey5" doc="Tiago++ left arm end-effector (pal-hey5 or pal-gripper)"/>
  <arg name="end_effector_right" default="pal-hey5" doc="Tiago++ right arm end-effector (pal-hey5 or pal-gripper)"/>
  <arg name="laser_model" default="sick-571"/>
  <arg name="camera_model" default="orbbec-astra"/>
  <arg name="gui" default="true" doc="Show Gazebo GUI"/>
  <arg name="gzpose" default="-x 0.0 -y 0.0 -z 0.0 -R 0.0 -P 0.0 -Y 0.0"/>

  <!-- Door Perception Config -->
  <arg name="door_config" default="$(find tiago_door_localization)/config/apriltag_two_sided_door.yaml"/>
  
  <!-- Navigation Configuration -->
  <arg name="approach_cfg" default="$(find tiago_move_base_control)/config/door_approach.yaml"/>

  <!-- Launch Components -->

  <!-- 1. Simulation / Robot -->
  <group if="$(arg simulation)">
    <include file="$(find tiago_door_sim)/launch/sim_with_door.launch">
      <arg name="world_file" value="$(arg world_file)"/>
      <arg name="robot" value="$(arg robot)"/>
      <arg name="arm" value="$(arg arm)"/>
      <arg name="end_effector" value="$(arg end_effector)"/>
      <arg name="end_effector_left"  value="$(arg end_effector_left)"/>
      <arg name="end_effector_right" value="$(arg end_effector_right)"/>
      <arg name="laser_model" value="$(arg laser_model)"/>
      <arg name="camera_model" value="$(arg camera_model)"/>
      <arg name="gui" value="$(arg gui)"/>
      <arg name="gzpose" value="$(arg gzpose)"/>
    </include>
  </group>

  <!-- 2. SLAM System -->
  <group if="$(arg use_slam)">
    <group unless="$(arg simulation)">
      <node name="kill_pal_nav_nodes" pkg="rosnode" type="rosnode"
            args="kill /amcl /map_server /map_aligner_node /map_configuration_server /compressed_map_publisher"
            output="screen" launch-prefix="bash -c 'sleep 5 &amp;&amp; $0 &quot;$@&quot;'"/>
    </group>
    <include file="$(find tiago_slam)/launch/tiago_slam.launch"/>
  </group>

  <!-- 3. Door Perception -->
  <group if="$(arg use_door_perception)">
    <include file="$(find tiago_door_localization)/launch/door_preception_tags.launch">
      <arg name="config" value="$(arg door_config)"/>
    </include>
  </group>

  <!-- 4. Navigation Control -->
  <group if="$(arg use_navigation)">
    <include file="$(find tiago_move_base_control)/launch/door_nav.launch">
      <arg name="approach_cfg" value="$(arg approach_cfg)"/>
    </include>
  </group>

  <!-- 5. Door Planning -->
  
  <!-- 6. Arm Manipulation -->
  <group if="$(arg use_arm_manipulation)">
    <include file="$(find tiago_arm_manipulation)/launch/arm_manipulation.launch"/>
  </group>

  <!-- 7. Behavior Tree -->
  <group if="$(arg use_behavior_tree)">
    <include file="$(find tiago_door_bt)/launch/door_bt.launch"/>
  </group>

  <!-- 8. VICON (Optional) -->
  <group if="$(arg use_vicon)">
    <include file="$(find tiago_vicon)/launch/tiago_vicon.launch"/>
  </group>

  <!-- 9. Visualization (RViz) -->
  <group if="$(arg rviz)">
    <node pkg="rviz" type="rviz" name="rviz" output="screen"
          args="-d $(find tiago_door_bringup)/rviz/tiago_door_nav.rviz" />
  </group>

  <!-- Logging & Status -->
  <node pkg="rostopic" type="rostopic" name="log_startup"
        args="echo -p 'TIAGo Door Navigation System Started'" output="screen"
        launch-prefix="bash -c 'sleep 3; '" />

</launch>
